rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // --- USERS COLLECTION ---
    // Private profile data (email, onboarding status) and nested user settings.
    // Strictly private to the user.
    match /users/{userId} {
      // Allow authenticated users to create/read/update their own profile document
      allow read, write: if isOwner(userId);

      // Allow authenticated users to read/write any subcollection under their user document
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- PORTFOLIOS COLLECTION ---
    // Content container. Keyed by User ID.
    match /portfolios/{userId} {
      // 1. Root Document (Metadata & Slug)
      // Owner: Full Control
      // Public: Can Get (to check isPublished) and List (to query by slug)
      allow write: if isOwner(userId);
      allow get: if true;
      allow list: if true;

      // 2. Versions Subcollection
      // This contains both the 'draft' (private) and published snapshots (public)
      match /versions/{versionId} {
        
        // Write: Only owner can write (drafts or snapshots)
        allow write: if isOwner(userId);

        // Read: 
        // 1. Owner can read everything (including draft).
        // 2. Public can read ONLY if it is NOT the draft AND matches the liveVersion.
        allow read: if isOwner(userId) || (
          versionId != 'draft' && 
          get(/databases/$(database)/documents/portfolios/$(userId)).data.publish.liveVersion == versionId
        );
      }
    }

    // --- ANALYTICS COLLECTION ---
    // Stores views/clicks.
    match /portfolio_stats/{userId} {
      // Owner can see their stats
      allow read: if isOwner(userId);
      
      // Public can Write (to increment counters).
      // We allow create/update for unauthenticated users for accurate view tracking.
      allow create, update: if true;
    }
  }
}