rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USERS: Private profile data
    match /users/{userId} {
      // Explicitly allow create (for onboarding), read, and write for the owner
      allow create: if isOwner(userId);
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // PORTFOLIOS: High-level metadata (slug, publish status)
    match /portfolios/{portfolioId} {
      allow read: if true; 
      allow write: if isOwner(portfolioId);
      
      // VERSIONS: Content snapshots
      match /versions/{versionId} {
        allow write: if isOwner(portfolioId);
        allow read: if isOwner(portfolioId) || true; 
      }
    }
    
    // ANALYTICS: Write-only for public (logging events), Owner read
    match /analytics/{portfolioId}/events/{eventId} {
      allow read: if isOwner(portfolioId);
      allow write: if true;
    }
    
    // Legacy Stats support
    match /portfolio_stats/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}