rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS: Allow users to read and write their own document. 
    // This covers create (if not exists), update, and read.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // PORTFOLIOS: Metadata
    match /portfolios/{portfolioId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == portfolioId;
      
      // VERSIONS: Content snapshots
      match /versions/{versionId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == portfolioId;
      }
    }
    
    // ANALYTICS
    match /analytics/{portfolioId}/events/{eventId} {
      allow read: if request.auth != null && request.auth.uid == portfolioId;
      allow write: if true;
    }
    
    // Legacy Stats support
    match /portfolio_stats/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}