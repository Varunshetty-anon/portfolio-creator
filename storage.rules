rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Helper Functions ---
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Check Firestore to see if the user's portfolio is currently published.
    function isPortfolioPublished(userId) {
      let portfolioPath = /databases/(default)/documents/portfolios/$(userId);
      return firestore.exists(portfolioPath) &&
             firestore.get(portfolioPath).data.publish.isPublished == true;
    }

    // --- USER MEDIA ---
    match /users/{userId} {
      
      // 1. Owner Access (Global for User)
      // Authenticated owners have full R/W access to their entire directory.
      // This ensures cleanup scripts and editor uploads work everywhere.
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
      
      // 2. Public Read Access (Specific Subfolders Only)
      // Only these folders are exposed, and only if the portfolio is published.
      
      match /profile/{allPaths=**} {
        allow read: if isPortfolioPublished(userId);
      }
      
      match /projects/{allPaths=**} {
        allow read: if isPortfolioPublished(userId);
      }
      
      match /showreels/{allPaths=**} {
        allow read: if isPortfolioPublished(userId);
      }
      
      // Note: All other folders (e.g. 'drafts', root files) are implicitly denied to the public.
    }
  }
}